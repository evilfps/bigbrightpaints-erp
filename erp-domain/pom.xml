    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>3.2.5</version>
                <configuration>
                    <skipTests>${skipTests}</skipTests>
                    <groups>${test.groups}</groups>
                    <excludedGroups>${test.excludedGroups}</excludedGroups>
                    <failIfNoTests>${test.failIfNoTests}</failIfNoTests>
                    <forkedProcessExitTimeoutInSeconds>180</forkedProcessExitTimeoutInSeconds>
                    <systemPropertyVariables>
                        <junit.jupiter.execution.parallel.enabled>false</junit.jupiter.execution.parallel.enabled>
                    </systemPropertyVariables>
                    <includes>
                        <include>**/*Tests.java</include>
                        <include>**/*Test.java</include>
                        <include>**/*IT.java</include>
                        <include>**/*ITCase.java</include>
                    </includes>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <configuration>
                    <source>${java.version}</source>
                    <target>${java.version}</target>
                    <annotationProcessorPaths>
                        <path>
                            <groupId>org.mapstruct</groupId>
                            <artifactId>mapstruct-processor</artifactId>
                            <version>${mapstruct.version}</version>
                        </path>
                        <path>
                            <groupId>org.projectlombok</groupId>
                            <artifactId>lombok</artifactId>
                            <version>1.18.32</version>
                        </path>
                    </annotationProcessorPaths>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.jacoco</groupId>
                <artifactId>jacoco-maven-plugin</artifactId>
                <version>0.8.12</version>
                <configuration>
                    <skip>${jacoco.skip}</skip>
                    <append>false</append>
                    <excludes>
                        <exclude>**/ErpDomainApplication*</exclude>
                        <exclude>**/*MapperImpl*</exclude>
                        <!-- Optional: exclude only if exceptions are truly trivial in this repo. -->
                        <!-- <exclude>**/*Exception*</exclude> -->
                    </excludes>
                </configuration>
                <executions>
                    <execution>
                        <goals>
                            <goal>prepare-agent</goal>
                        </goals>
                    </execution>
                    <execution>
                        <id>report</id>
                        <phase>test</phase>
                        <goals>
                            <goal>report</goal>
                        </goals>
                    </execution>
                    <execution>
                        <id>check</id>
                        <phase>verify</phase>
                        <goals>
                            <goal>check</goal>
                        </goals>
                        <configuration>
                            <rules>
                                <rule>
                                    <element>PACKAGE</element>
                                    <includes>
                                        <include>com.bigbrightpaints.erp.modules.accounting.domain*</include>
                                        <include>com.bigbrightpaints.erp.modules.accounting.service*</include>

                                        <include>com.bigbrightpaints.erp.modules.inventory.domain*</include>
                                        <include>com.bigbrightpaints.erp.modules.inventory.service*</include>

                                        <include>com.bigbrightpaints.erp.modules.invoice.domain*</include>
                                        <include>com.bigbrightpaints.erp.modules.invoice.service*</include>

                                        <include>com.bigbrightpaints.erp.orchestrator.policy*</include>
                                        <include>com.bigbrightpaints.erp.orchestrator.service*</include>
                                        <include>com.bigbrightpaints.erp.orchestrator.workflow*</include>
                                    </includes>
                                    <limits>
                                        <limit>
                                            <counter>LINE</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>${jacoco.tierA.line.minimum}</minimum>
                                        </limit>
                                        <limit>
                                            <counter>BRANCH</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>${jacoco.tierA.branch.minimum}</minimum>
                                        </limit>
                                    </limits>
                                </rule>

                                <rule>
                                    <element>BUNDLE</element>
                                    <limits>
                                        <limit>
                                            <counter>LINE</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>${jacoco.bundle.line.minimum}</minimum>
                                        </limit>
                                        <limit>
                                            <counter>BRANCH</counter>
                                            <value>COVEREDRATIO</value>
                                            <minimum>${jacoco.bundle.branch.minimum}</minimum>
                                        </limit>
                                    </limits>
                                </rule>
                            </rules>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.pitest</groupId>
                <artifactId>pitest-maven</artifactId>
                <version>1.16.3</version>
                <configuration>
                    <skip>${pitest.skip}</skip>
                    <mutationThreshold>${pitest.mutation.threshold}</mutationThreshold>
                    <threads>4</threads>
                    <outputFormats>
                        <param>XML</param>
                        <param>HTML</param>
                    </outputFormats>
                    <targetClasses>
                        <param>com.bigbrightpaints.erp.modules.accounting.service.CompanyDefaultAccountsService</param>
                        <param>com.bigbrightpaints.erp.modules.inventory.service.BatchNumberService</param>
                        <param>com.bigbrightpaints.erp.modules.invoice.service.InvoiceSettlementPolicy</param>
                        <param>com.bigbrightpaints.erp.orchestrator.policy.PolicyEnforcer</param>
                        <param>com.bigbrightpaints.erp.orchestrator.service.TraceService</param>
                        <param>com.bigbrightpaints.erp.orchestrator.service.OrchestratorIdempotencyService</param>
                    </targetClasses>
                    <targetTests>
                        <param>com.bigbrightpaints.erp.truthsuite.o2c.TS_O2CDispatchCanonicalPostingTest</param>
                        <param>com.bigbrightpaints.erp.truthsuite.p2p.TS_P2PGoodsReceiptIdempotencyTest</param>
                        <param>com.bigbrightpaints.erp.truthsuite.p2p.TS_P2PPurchaseJournalLinkageTest</param>
                        <param>com.bigbrightpaints.erp.truthsuite.payroll.TS_PayrollLiabilityClearingPolicyTest</param>
                        <param>com.bigbrightpaints.erp.truthsuite.periodclose.TS_PeriodCloseAtomicSnapshotTest</param>
                        <param>com.bigbrightpaints.erp.truthsuite.reports.TS_ReportSnapshotSourceSelectionTest</param>
                        <param>com.bigbrightpaints.erp.truthsuite.catalog.TS_CatalogImportCompanyScopedIdempotencyTest</param>
                        <param>com.bigbrightpaints.erp.truthsuite.manufacturing.TS_PackingIdempotencyAndFacadeBoundaryTest</param>
                        <param>com.bigbrightpaints.erp.truthsuite.manufacturing.TS_BulkPackDeterministicReferenceTest</param>
                        <param>com.bigbrightpaints.erp.truthsuite.orchestrator.TS_OrchestratorExactlyOnceOutboxTest</param>
                        <param>com.bigbrightpaints.erp.truthsuite.accounting.TS_DoubleEntryMathInvariantTest</param>
                        <param>com.bigbrightpaints.erp.truthsuite.accounting.TS_SubledgerControlReconciliationContractTest</param>
                        <param>com.bigbrightpaints.erp.truthsuite.tax.TS_GstRoundingDeterminismContractTest</param>
                        <param>com.bigbrightpaints.erp.truthsuite.crossmodule.TS_CrossModuleLinkageContractTest</param>
                        <param>com.bigbrightpaints.erp.truthsuite.inventory.TS_InventoryCogsLinkageScanContractTest</param>
                        <param>com.bigbrightpaints.erp.truthsuite.runtime.TS_RuntimeModuleExecutableCoverageTest</param>
                        <param>com.bigbrightpaints.erp.truthsuite.runtime.TS_RuntimeOrchestratorExecutableCoverageTest</param>
                        <param>com.bigbrightpaints.erp.truthsuite.runtime.TS_RuntimeEventPublisherExecutableCoverageTest</param>
                        <param>com.bigbrightpaints.erp.truthsuite.runtime.TS_RuntimeTraceServiceExecutableCoverageTest</param>
                        <param>com.bigbrightpaints.erp.truthsuite.runtime.TS_RuntimeOrchestratorIdempotencyExecutableCoverageTest</param>
                    </targetTests>
                </configuration>
                <dependencies>
                    <dependency>
                        <groupId>org.pitest</groupId>
                        <artifactId>pitest-junit5-plugin</artifactId>
                        <version>1.2.1</version>
                    </dependency>
                </dependencies>
            </plugin>
            <!-- Checkstyle plugin runs in advisory mode (failsOnError=false) to provide
                 code quality feedback without blocking builds. Teams can review reports
                 and gradually improve code style without disrupting development flow. -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-checkstyle-plugin</artifactId>
                <version>3.3.1</version>
                <configuration>
                    <configLocation>google_checks.xml</configLocation>
                    <consoleOutput>true</consoleOutput>
                    <failsOnError>false</failsOnError>
                    <violationSeverity>warning</violationSeverity>
                </configuration>
            </plugin>
        </plugins>
    </build>

    <profiles>
        <!-- Use when Docker is unavailable (e.g., lightweight CI runners) to skip Testcontainers-based suites and coverage. -->
        <profile>
            <id>ci-no-docker</id>
            <properties>
                <skipTests>true</skipTests>
                <jacoco.skip>true</jacoco.skip>
            </properties>
        </profile>

        <!-- CODE-RED: run only the isolated parallel test suite under src/test/java/**/codered/ -->
        <profile>
            <id>codered</id>
            <properties>
                <skipTests>false</skipTests>
                <!-- Coverage gates are not meaningful for CODE-RED invariants; keep suite fast and isolated. -->
                <jacoco.skip>true</jacoco.skip>
