    <artifactId>erp-domain</artifactId>
    <version>0.1.0-SNAPSHOT</version>
    <name>BigBright ERP Domain Service</name>
    <description>Core domain APIs for BigBright ERP (multi-company, accounting, inventory, sales, HR)</description>

    <properties>
        <java.version>21</java.version>
        <mapstruct.version>1.5.5.Final</mapstruct.version>
        <testcontainers.version>1.20.2</testcontainers.version>
        <skipTests>false</skipTests>
        <jacoco.skip>false</jacoco.skip>
        <test.groups></test.groups>
        <test.excludedGroups></test.excludedGroups>
        <test.failIfNoTests>true</test.failIfNoTests>
        <pitest.skip>true</pitest.skip>
        <pitest.mutation.threshold>0</pitest.mutation.threshold>

        <!-- Coverage gates (ratchet upward over time). -->
        <!-- Baseline + ratchet plan (keep it realistic, push hard weekly):
             Week 0: Tier A ~0.38 line / ~0.31 branch, Bundle ~0.58 line / ~0.39 branch (no backsliding)
             Week 1: Tier A 0.55/0.40, Bundle 0.65/0.45
             Week 2: Tier A 0.70/0.55, Bundle 0.75/0.55
             Week 3+: Tier A 0.90-0.95 / 0.85-0.90, Bundle 0.85-0.90 / 0.70-0.80
        -->
        <!-- Tier A gate is intentionally "tight but achievable" from day 0.
             We ratchet these up (weekly) until Tier A is 0.90-0.95 line / 0.85-0.90 branch.
        -->
        <jacoco.tierA.line.minimum>0.38</jacoco.tierA.line.minimum>
        <jacoco.tierA.branch.minimum>0.31</jacoco.tierA.branch.minimum>

        <!-- Bundle gate is a "no backsliding" safety rail.
             Ratchet upward as Tier A grows.
        -->
        <jacoco.bundle.line.minimum>0.55</jacoco.bundle.line.minimum>
        <jacoco.bundle.branch.minimum>0.36</jacoco.bundle.branch.minimum>
    </properties>

