# =============================================================================
# BigBright ERP Backend - Production Template
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime Profile
# -----------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=prod
# Use prod,seed ONLY for first bootstrapping, then switch back to prod.
# SPRING_PROFILES_ACTIVE=prod,seed

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Primary datasource used by prod profile (flyway-v2 profile can override with V2 vars)
SPRING_DATASOURCE_URL=jdbc:postgresql://db-host:5432/erp_domain
SPRING_DATASOURCE_USERNAME=erp
SPRING_DATASOURCE_PASSWORD=change-me
# Optional flyway-v2 datasource overrides (defaults to the primary DB unless intentionally split)
SPRING_DATASOURCE_V2_URL=jdbc:postgresql://db-host:5432/erp_domain
SPRING_DATASOURCE_V2_USERNAME=erp
SPRING_DATASOURCE_V2_PASSWORD=change-me
SPRING_DATASOURCE_POOL_MAX=30
SPRING_DATASOURCE_POOL_MIN=5

# -----------------------------------------------------------------------------
# JWT Security
# -----------------------------------------------------------------------------
# Must be >= 32 bytes (256 bits)
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_SECRET
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
# Required for AES-256-GCM encryption (32+ bytes)
ERP_SECURITY_ENCRYPTION_KEY=REPLACE_WITH_32_PLUS_BYTE_RANDOM_KEY
# Required for private audit payload signing in production
ERP_SECURITY_AUDIT_PRIVATE_KEY=REPLACE_WITH_STRONG_AUDIT_PRIVATE_KEY

# -----------------------------------------------------------------------------
# RabbitMQ
# -----------------------------------------------------------------------------
SPRING_RABBITMQ_HOST=rabbitmq
SPRING_RABBITMQ_PORT=5672
SPRING_RABBITMQ_USERNAME=guest
SPRING_RABBITMQ_PASSWORD=guest

# -----------------------------------------------------------------------------
# Email (SMTP)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=replace-me
SMTP_PASSWORD=replace-me
# Spring fallback variables (docker-compose/app.yml compatible)
SPRING_MAIL_HOST=smtp-relay.brevo.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=replace-me
SPRING_MAIL_PASSWORD=replace-me
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=true
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_REQUIRED=true
ERP_MAIL_FROM=noreply@yourdomain.com
ERP_MAIL_BASE_URL=https://app.yourdomain.com

# -----------------------------------------------------------------------------
# Licensing (required when enforce=true)
# -----------------------------------------------------------------------------
ERP_LICENSE_ENFORCE=true
ERP_LICENSE_KEY=CHANGE-ME-LICENSE
ERP_LICENSE_PRODUCT_ID=31720
ERP_LICENSE_ALGORITHM=SKM15
ERP_LICENSE_CREATED=2025-12-08
ERP_LICENSE_DESCRIPTION=ERP
ERP_LICENSE_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Dispatch Journal Mapping (required for dispatch postings)
# -----------------------------------------------------------------------------
ERP_DISPATCH_DEBIT_ACCOUNT_ID=3
ERP_DISPATCH_CREDIT_ACCOUNT_ID=6

# -----------------------------------------------------------------------------
# Optional GitHub support ticket integration
# -----------------------------------------------------------------------------
ERP_GITHUB_ENABLED=false
ERP_GITHUB_TOKEN=
ERP_GITHUB_REPO_OWNER=
ERP_GITHUB_REPO_NAME=

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
ERP_CORS_ALLOWED_ORIGINS=https://app.yourdomain.com,https://admin.yourdomain.com
ERP_CORS_ALLOW_TAILSCALE_HTTP_ORIGINS=false
MANAGEMENT_CORS_ALLOWED_ORIGINS=https://ops.yourdomain.com

# -----------------------------------------------------------------------------
# Production safety + monitoring
# -----------------------------------------------------------------------------
# Keep true in production to fail health when required runtime config is missing
ERP_ENVIRONMENT_VALIDATION_ENABLED=true
# Optional OpenTelemetry export configuration (Micrometer OTLP bridge)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_EXPORTER_OTLP_TIMEOUT=5s
MANAGEMENT_TRACING_SAMPLING_PROBABILITY=1.0
# Graceful shutdown timeout for in-flight requests
SPRING_LIFECYCLE_TIMEOUT_PER_SHUTDOWN_PHASE=30s

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
SERVER_PORT=8081
MANAGEMENT_SERVER_PORT=9090
SERVER_TOMCAT_MAX_THREADS=200

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
ERP_RATE_LIMIT_RPM=60

# -----------------------------------------------------------------------------
# Optional docker-compose host port overrides
# -----------------------------------------------------------------------------
DB_PORT=5432
RABBIT_PORT=5672
RABBIT_MANAGEMENT_PORT=15672
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
APP_PORT=8081
MANAGEMENT_PORT=9090

# -----------------------------------------------------------------------------
# Sentry (Error & Performance Monitoring)
# -----------------------------------------------------------------------------
SENTRY_DSN=https://your-key@your-org.ingest.de.sentry.io/your-project-id
SENTRY_TRACES_SAMPLE_RATE=0.2

# -----------------------------------------------------------------------------
# Datadog (Infrastructure & APM Monitoring)
# -----------------------------------------------------------------------------
DD_API_KEY=your-datadog-api-key
DD_SITE=us5.datadoghq.com
DD_ENV=prod
DD_TRACE_SAMPLE_RATE=0.2
DD_PROFILING_ENABLED=true
