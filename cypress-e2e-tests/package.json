{
  "name": "bigbright-erp-e2e-tests",
  "version": "1.0.0",
  "description": "End-to-end tests for BigBright ERP system using Cypress",
  "main": "cypress.config.js",
  "scripts": {
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "cypress:run:headed": "cypress run --headed",
    
    "test:setup": "cypress run --spec 'cypress/e2e/setup/**/*.cy.js'",
    "test:api": "cypress run --spec 'cypress/e2e/api/**/*.cy.js'",
    "test:ui": "cypress run --spec 'cypress/e2e/ui/**/*.cy.js'",
    "test:workflows": "cypress run --spec 'cypress/e2e/workflows/**/*.cy.js'",
    "test:all": "cypress run --spec 'cypress/e2e/**/*.cy.js'",
    
    "test:auth": "cypress run --spec 'cypress/e2e/api/01-authentication.cy.js'",
    "test:sales": "cypress run --spec 'cypress/e2e/api/02-sales-management.cy.js'",
    "test:dealers": "cypress run --spec 'cypress/e2e/ui/02-dealer-management.cy.js'",
    "test:order-flow": "cypress run --spec 'cypress/e2e/workflows/01-order-to-cash-flow.cy.js'",
    
    "test:smoke": "cypress run --spec 'cypress/e2e/setup/01-initial-setup.cy.js,cypress/e2e/api/01-authentication.cy.js,cypress/e2e/ui/01-login-and-navigation.cy.js'",
    "test:critical": "cypress run --spec 'cypress/e2e/workflows/**/*.cy.js'",
    
    "test:dev": "cypress run --config-file cypress.config.dev.js",
    "test:prod": "cypress run --config-file cypress.config.prod.js",
    
    "db:seed": "node -e \"require('./cypress/plugins/seed-tasks.js')({dealerCount:10, orderCount:20})\"",
    "db:cleanup": "node -e \"require('./cypress/plugins/cleanup-tasks.js')({cleanupOrders:true, cleanupDealers:true})\"",
    
    "setup:check": "node setup-check.js",
    "setup:quick": "./quick-start.sh",
    "setup:install": "npm install && npm run setup:check",
    
    "report:open": "npx cypress run --reporter mochawesome --reporter-options reportDir=cypress/reports,overwrite=false,html=true,json=true && open cypress/reports/mochawesome.html",
    "report:merge": "npx mochawesome-merge cypress/reports/*.json > cypress/reports/merged-report.json && npx marge cypress/reports/merged-report.json --reportDir cypress/reports --inline",
    
    "ci:test": "cypress run --record --parallel --group 'E2E Tests'",
    "ci:smoke": "cypress run --spec 'cypress/e2e/setup/**/*.cy.js,cypress/e2e/api/01-authentication.cy.js' --record",
    
    "debug:api": "cypress run --spec 'cypress/e2e/api/**/*.cy.js' --headed --no-exit",
    "debug:ui": "cypress run --spec 'cypress/e2e/ui/**/*.cy.js' --headed --no-exit",
    
    "lint": "eslint cypress/**/*.js",
    "lint:fix": "eslint cypress/**/*.js --fix"
  },
  "keywords": [
    "cypress",
    "e2e",
    "testing",
    "erp",
    "bigbright",
    "api-testing",
    "ui-testing",
    "automation"
  ],
  "author": "BigBright ERP Team",
  "license": "MIT",
  "devDependencies": {
    "cypress": "^13.6.0",
    "pg": "^8.11.3",
    "@faker-js/faker": "^8.3.1",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0",
    "eslint": "^8.55.0",
    "eslint-plugin-cypress": "^2.15.1"
  },
  "dependencies": {},
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/bigbright-erp-e2e-tests.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/bigbright-erp-e2e-tests/issues"
  },
  "homepage": "https://github.com/your-org/bigbright-erp-e2e-tests#readme",
  "cypress-cucumber-preprocessor": {
    "nonGlobalStepDefinitions": false,
    "stepDefinitions": "cypress/integration/common/step_definitions/"
  }
}
