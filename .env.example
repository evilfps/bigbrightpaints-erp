# =============================================================================
# BigBright ERP Backend Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/erp_domain
SPRING_DATASOURCE_USERNAME=erp
SPRING_DATASOURCE_PASSWORD=erp
SPRING_PROFILES_ACTIVE=dev

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# JWT Secret - Must be at least 32 bytes; use a strong random value in production
# Generate with: openssl rand -base64 32
JWT_SECRET=YOUR_JWT_SECRET_HERE
ERP_SECURITY_ENCRYPTION_KEY=YOUR_ENCRYPTION_KEY_HERE

# -----------------------------------------------------------------------------
# Accounting Configuration
# -----------------------------------------------------------------------------
# Dispatch journal mapping (required to post dispatch journals)
# Set these to the correct Inventory (debit) and COGS (credit) accounts for your environment
ERP_DISPATCH_DEBIT_ACCOUNT_ID=0
ERP_DISPATCH_CREDIT_ACCOUNT_ID=0

# -----------------------------------------------------------------------------
# CORS Configuration
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins for CORS
# For production: https://app.bigbrightpaints.com,https://admin.bigbrightpaints.com
ERP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:3004
ERP_CORS_ALLOW_TAILSCALE_HTTP_ORIGINS=false

# -----------------------------------------------------------------------------
# Email Configuration (MailHog-safe local defaults)
# -----------------------------------------------------------------------------
SPRING_MAIL_HOST=mailhog
SPRING_MAIL_PORT=1025
SPRING_MAIL_USERNAME=mailhog
SPRING_MAIL_PASSWORD=mailhog
SPRING_MAIL_PROPERTIES_MAIL_SMTP_AUTH=false
SPRING_MAIL_PROPERTIES_MAIL_SMTP_STARTTLS_ENABLE=false

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
SERVER_PORT=8081

# -----------------------------------------------------------------------------
# Production Deployment Notes
# -----------------------------------------------------------------------------
# 1. Change SPRING_PROFILES_ACTIVE to 'prod'
# 2. Set a strong JWT_SECRET (minimum 32 bytes)
# 3. Configure production database credentials
# 4. Set ERP_CORS_ALLOWED_ORIGINS to your frontend domain(s)
# 5. Configure email credentials for notifications
# 6. Set up proper SSL termination via reverse proxy
